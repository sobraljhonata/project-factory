NODE_ENV=development
PORT=3000
API_VERSION=v1
SWAGGER_ENABLED=true

# Mínimo 16 no stack base; com módulo opcional auth-jwt instalado exige-se ≥32 (ver README do módulo).
JWT_SECRET=change-me-min-32-chars-aaaaaaaaaaaaaa
JWT_ACCESS_SECRET=change-me-min-32-chars-bbbbbbbbbbbbbb
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-min-32-chars-cccccccccccccc
JWT_REFRESH_EXPIRES_IN=7d

# Opcional (módulo auth-jwt): validar iss/aud de tokens emitidos externamente
# JWT_ISSUER=
# JWT_AUDIENCE=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=dev-only-change-me

DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_app
DB_USERNAME=user_app
DB_PASSWORD=

# Com `true`, GET /ready exige MySQL (sequelize.authenticate). Use `false` até o banco existir localmente.
READINESS_CHECK_DB=false
