NODE_ENV=development
PORT=3000
API_VERSION=v1
SWAGGER_ENABLED=true

JWT_SECRET=change-me-min-16-chars-aaaaaaaa
JWT_ACCESS_SECRET=change-me-min-16-chars-bbbbbbbb
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-min-16-chars-cccccccc
JWT_REFRESH_EXPIRES_IN=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=dev-only-change-me

DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_app
DB_USERNAME=user_app
DB_PASSWORD=

# Com `true`, GET /ready exige MySQL (sequelize.authenticate). Use `false` até o banco existir localmente.
READINESS_CHECK_DB=false
