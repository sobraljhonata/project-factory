# Copie para terraform.tfvars (gitignored no repo raiz **/terraform.tfvars).
#
# Valores de VPC/subnets (stack foundation já aplicado no mesmo account/region):
#   cd ../foundation
#   terraform output -raw vpc_id
#   terraform output -json private_subnet_ids   # se der "not found", rode terraform apply no foundation
#   terraform output -json public_subnet_ids
# Alternativa imediata (sem depender do output no state):
#   printf '%s\n' 'jsonencode(aws_subnet.private[*].id)' | terraform console
#
# Colar o JSON como lista HCL, ex.:
#   database_subnet_ids = ["subnet-aaa", "subnet-bbb"]

aws_region   = "us-east-1"
project_name = "{{PROJECT_SLUG}}"
environment  = "dev"

vpc_id = "vpc-0b22c96cd4b3a1e1e"

database_subnet_ids = [
  "subnet-aaaaaaa",
  "subnet-bbbbbbb",
]

allowed_cidr_blocks = ["203.0.113.50/32"]

# Quando a API rodar no ECS no mesmo VPC:
# allowed_security_group_ids = ["sg-ecs-tasks"]

publicly_accessible = true
