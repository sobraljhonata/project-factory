{
  "name": "{{PACKAGE_NAME}}",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon",
    "build": "NODE_ENV=production tsc -p tsconfig.json && tsc-alias -p tsconfig.json && npm run copy:src/core/docs",
    "start": "node dist/server.js",
    "start:debug": "node --inspect dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "lint:ci": "eslint src",
    "copy:src/core/docs": "copyfiles -u 1 \"src/core/docs/**/*\" dist",
    "test": "NODE_ENV=test jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "NODE_ENV=test jest --passWithNoTests --runInBand",
    "test:ci": "npm test -- --coverage",
    "smoke:http": "node scripts/smoke-http.cjs",
    "check": "npm run typecheck && npm run lint && npm run test:ci",
    "db:migrate": "node scripts/sequelize-with-node-env.cjs db:migrate",
    "db:migrate:undo": "node scripts/sequelize-with-node-env.cjs db:migrate:undo",
    "db:migrate:status": "node scripts/sequelize-with-node-env.cjs db:migrate:status",
    "verify:dist": "node scripts/verify-dist.cjs",
    "check:rds-ca": "node scripts/check-rds-ca-path.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "copyfiles": "^2.4.1",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "mysql2": "^3.14.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^4.1.12"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
